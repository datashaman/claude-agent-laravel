{
    "name": "datashaman/claude-agent-laravel",
    "description": "Laravel companion package for datashaman/claude-agent-sdk",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "DataShaman",
            "email": "marlin@datashaman.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "datashaman/claude-agent-sdk": "^0.1",
        "illuminate/contracts": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "livewire/livewire": "^3.0",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "DataShaman\\Claude\\AgentLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DataShaman\\Claude\\AgentLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DataShaman\\Claude\\AgentLaravel\\ClaudeServiceProvider"
            ],
            "aliases": {
                "Claude": "DataShaman\\Claude\\AgentLaravel\\Facades\\Claude"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
